@client.event
async def on_message(message):
    if message.author.bot:
        return
    if "!" in str(message.content):

        msg = message.content
        cmd = msg.replace("!","")

        command = subprocess.run(cmd, capture_output=True, text=True,shell=True)

        msgd = str(command.stdout.encode()).replace("b'","").replace(r"\n'"," ").replace(r"\n"," ")
        await message.channel.send(msgd)
    elif ";" in str(message.content):
        print("Built in command")





